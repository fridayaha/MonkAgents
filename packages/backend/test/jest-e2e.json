{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@monkagents/shared$": "<rootDir>/../../shared/src",
    "^src/(.*)$": "<rootDir>/../src/$1"
  }
}