{
  "name": "monkagents",
  "version": "0.1.0",
  "description": "Multi-agent collaboration platform based on Journey to the West characters",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @monkagents/shared && npm run build -w @monkagents/backend",
    "start": "npm run start -w @monkagents/backend",
    "start:dev": "npm run start:dev -w @monkagents/backend",
    "start:frontend": "cd packages/frontend && npm run dev",
    "start:all": "node scripts/start-all.js",
    "stop": "node scripts/stop-all.js",
    "stop:backend": "node scripts/stop-backend.js",
    "stop:frontend": "node scripts/stop-frontend.js",
    "restart": "node scripts/stop-all.js && node scripts/start-all.js",
    "restart:backend": "node scripts/stop-backend.js && npm run start:dev",
    "restart:frontend": "node scripts/stop-frontend.js && npm run start:frontend",
    "status": "node scripts/status.js",
    "test": "npm run test -w @monkagents/shared && npm run test -w @monkagents/backend",
    "test:watch": "npm run test:watch -w @monkagents/backend",
    "test:cov": "npm run test:cov -w @monkagents/backend",
    "test:e2e": "npm run test:e2e -w @monkagents/backend",
    "lint": "eslint packages/*/src --ext .ts",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "multi-agent",
    "ai",
    "collaboration",
    "nest",
    "claude"
  ],
  "author": "",
  "license": "MIT"
}
